            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='Churn Rate on Additional Internet Service' datatype='string' name='[Parameter 1]' param-domain-type='list' role='measure' type='nominal' value='&quot;Churn Rate by Streaming Movies&quot;'>
              <calculation class='tableau' formula='&quot;Churn Rate by Streaming Movies&quot;' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.05518kp1ejy3vz1fgso431sue2hv'>
            <column caption='Churn Rate on Additional Internet Service Selector' datatype='string' name='[Calculation_724798109061431296]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='CASE [Parameters].[Parameter 1]&#13;&#10;    WHEN &quot;Churn Rate by Online Security&quot; THEN &quot;Churn Rate by Online Security&quot;&#13;&#10;    WHEN &quot;Churn Rate by Online Backup&quot; THEN &quot;Churn Rate by Online Backup&quot;&#13;&#10;    WHEN &quot;Churn Rate by Device Protection&quot; THEN &quot;Churn Rate by Device Protection&quot;&#13;&#10;    WHEN &quot;Churn Rate by Tech Support&quot; THEN &quot;Churn Rate by Tech Support&quot;&#13;&#10;    WHEN &quot;Churn Rate by Streaming TV&quot; THEN &quot;Churn Rate by Streaming TV&quot;&#13;&#10;    WHEN &quot;Churn Rate by Streaming Movies&quot; THEN &quot;Churn Rate by Streaming Movies&quot;&#13;&#10;END' />
            </column>
            <column datatype='string' name='[Churn]' role='dimension' type='nominal' />
            <column datatype='string' name='[StreamingTV]' role='dimension' type='nominal' />
            <column-instance column='[customerID]' derivation='CountD' name='[ctd:customerID:qk]' pivot='key' type='quantitative' />
            <column datatype='string' name='[customerID]' role='dimension' type='nominal' />
            <column-instance column='[Calculation_724798109061431296]' derivation='None' name='[none:Calculation_724798109061431296:nk]' pivot='key' type='nominal' />
            <column-instance column='[Churn]' derivation='None' name='[none:Churn:nk]' pivot='key' type='nominal' />
            <column-instance column='[StreamingTV]' derivation='None' name='[none:StreamingTV:nk]' pivot='key' type='nominal' />
            <column-instance column='[customerID]' derivation='CountD' name='[pcto:ctd:customerID:qk:2]' pivot='key' type='quantitative'>
              <table-calc ordering-type='Columns' type='PctTotal' />
            </column-instance>
          </datasource-dependencies>
          <filter class='categorical' column='[federated.05518kp1ejy3vz1fgso431sue2hv].[none:Calculation_724798109061431296:nk]'>
            <groupfilter function='member' level='[none:Calculation_724798109061431296:nk]' member='&quot;Churn Rate by Streaming TV&quot;' user:ui-domain='database' user:ui-enumeration='inclusive' user:ui-marker='enumerate' />
          </filter>
          <manual-sort column='[federated.05518kp1ejy3vz1fgso431sue2hv].[none:Churn:nk]' direction='ASC'>
            <dictionary>
              <bucket>&quot;Yes&quot;</bucket>
              <bucket>&quot;No&quot;</bucket>
