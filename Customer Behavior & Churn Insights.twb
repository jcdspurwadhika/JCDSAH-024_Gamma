      <column caption='Core Services' datatype='string' name='[Calculation_635852015103582213]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [PhoneService] = &quot;No&quot; THEN &quot;PhoneService-No&quot;&#13;&#10;ELSEIF [PhoneService] = &quot;Yes&quot; THEN &quot;PhoneService-Yes&quot;&#13;&#10;END' />
