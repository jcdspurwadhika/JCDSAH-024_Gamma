    <worksheet name='Churn Rate by Number of Services'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontalignment='1' fontcolor='#b07aa1' fontname='Tw Cen MT Condensed Extra Bold' fontsize='12'>&lt;</run>
            <run bold='true' fontalignment='1' fontcolor='#b07aa1' fontname='Tw Cen MT Condensed Extra Bold' fontsize='12'>[Parameters].[Parameter 5]</run>
            <run bold='true' fontalignment='1' fontcolor='#b07aa1' fontname='Tw Cen MT Condensed Extra Bold' fontsize='12'>&gt;</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Sheet1 (Telco Custemer Churn)' name='federated.05518kp1ejy3vz1fgso431sue2hv' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='Churn Rate by Another Factors' datatype='string' name='[Parameter 5]' param-domain-type='list' role='measure' type='nominal' value='&quot;Churn Rate by Number of Services&quot;'>
              <calculation class='tableau' formula='&quot;Churn Rate by Number of Services&quot;' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.05518kp1ejy3vz1fgso431sue2hv'>
            <column caption='Churn Rate by Another Factors' datatype='string' name='[Calculation_1047931382770462725]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='CASE [Parameters].[Parameter 5]&#13;&#10;    WHEN &quot;Churn Rate by Payment Method&quot; THEN &quot;Churn Rate by Payment Method&quot;&#13;&#10;    WHEN &quot;Churn Rate by Tenure&quot; THEN &quot;Churn Distribution by Tenure&quot;&#13;&#10;    WHEN &quot;Churn Rate by Contract&quot; THEN &quot;Churn Rate Distribution by Contract&quot;&#13;&#10;    WHEN &quot;Churn Rate by Paperless Billing Adoption&quot; THEN &quot;Churn Distribution by PaperlessBilling Adoption&quot;&#13;&#10;    WHEN &quot;Churn Rate by Number of Services&quot; THEN &quot;Churn Rate by Number of Services&quot;&#13;&#10;END' />
            </column>
            <column caption='Total Services' datatype='integer' name='[Calculation_1546705042086137856]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='INT([PhoneService] = &quot;Yes&quot;)&#13;&#10;+&#13;&#10;INT([MultipleLines] = &quot;Yes&quot;)&#13;&#10;+&#13;&#10;INT([OnlineSecurity] = &quot;Yes&quot;)&#13;&#10;+&#13;&#10;INT([OnlineBackup] = &quot;Yes&quot;)&#13;&#10;+&#13;&#10;INT([DeviceProtection] = &quot;Yes&quot;)&#13;&#10;+&#13;&#10;INT([TechSupport] = &quot;Yes&quot;)&#13;&#10;+&#13;&#10;INT([StreamingTV] = &quot;Yes&quot;)&#13;&#10;+&#13;&#10;INT([StreamingMovies] = &quot;Yes&quot;)' />
            </column>
            <column caption='Churn Flag' datatype='integer' name='[Calculation_1546705042086612993]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [Churn] = &quot;Yes&quot; THEN 1 ELSE 0 END' />
            </column>
            <column datatype='string' name='[Churn]' role='dimension' type='nominal' />
            <column datatype='string' name='[DeviceProtection]' role='dimension' type='nominal' />
            <column datatype='string' name='[MultipleLines]' role='dimension' type='nominal' />
            <column datatype='string' name='[OnlineBackup]' role='dimension' type='nominal' />
            <column datatype='string' name='[OnlineSecurity]' role='dimension' type='nominal' />
            <column datatype='string' name='[PhoneService]' role='dimension' type='nominal' />
            <column datatype='string' name='[StreamingMovies]' role='dimension' type='nominal' />
            <column datatype='string' name='[StreamingTV]' role='dimension' type='nominal' />
