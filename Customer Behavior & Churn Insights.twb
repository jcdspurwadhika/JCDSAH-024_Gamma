          </manual-sort>
          <manual-sort column='[federated.05518kp1ejy3vz1fgso431sue2hv].[none:StreamingTV:nk]' direction='ASC'>
            <dictionary>
              <bucket>&quot;No&quot;</bucket>
              <bucket>&quot;Yes&quot;</bucket>
              <bucket>&quot;No internet service&quot;</bucket>
            </dictionary>
          </manual-sort>
          <slices>
