      <column caption='Uses Extra Service' datatype='string' name='[Calculation_303148592995045377]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [OnlineSecurity] = &quot;Yes&quot;&#13;&#10;OR [OnlineBackup] = &quot;Yes&quot;&#13;&#10;OR [DeviceProtection] = &quot;Yes&quot;&#13;&#10;OR [TechSupport] = &quot;Yes&quot;&#13;&#10;OR [StreamingTV] = &quot;Yes&quot;&#13;&#10;OR [StreamingMovies] = &quot;Yes&quot;&#13;&#10;THEN &quot;Yes&quot;&#13;&#10;END' />
