      <column caption='Tenure Group' datatype='string' name='[Calculation_635852015106342921]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [tenure] &lt;= 6 THEN &quot;0-6&quot;&#13;&#10;ELSEIF [tenure] &lt;= 12 THEN &quot;7-12&quot;&#13;&#10;ELSEIF [tenure] &lt;= 18 THEN &quot;13-18&quot;&#13;&#10;ELSEIF [tenure] &lt;= 24 THEN &quot;19-24&quot;&#13;&#10;ELSEIF [tenure] &lt;= 30 THEN &quot;25-30&quot;&#13;&#10;ELSEIF [tenure] &lt;= 36 THEN &quot;31-36&quot;&#13;&#10;ELSEIF [tenure] &lt;= 42 THEN &quot;37-42&quot;&#13;&#10;ELSEIF [tenure] &lt;= 48 THEN &quot;43-48&quot;&#13;&#10;ELSEIF [tenure] &lt;= 54 THEN &quot;49-54&quot;&#13;&#10;ELSEIF [tenure] &lt;= 60 THEN &quot;55-60&quot;&#13;&#10;ELSEIF [tenure] &lt;= 66 THEN &quot;61-66&quot;&#13;&#10;ELSE &quot;67-72&quot;&#13;&#10;END' />
      </column>
